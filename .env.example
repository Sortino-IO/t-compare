# Copy to .env.local and fill in. NEXT_PUBLIC_* are exposed to the browser.

# Canonical site URL (no trailing slash). Used for sitemap, robots, OG URLs, JSON-LD.
#NEXT_PUBLIC_SITE_URL=https://www.t-compare.com

# Google Tag Manager container ID (e.g. GTM-XXXXXXX)
#NEXT_PUBLIC_GTM_ID=

# Google Search Console - HTML tag method: value from content="..."
# https://search.google.com/search-console
#NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools - value from content="..." of msvalidate.01 meta
# https://www.bing.com/webmasters
#NEXT_PUBLIC_BING_SITE_VERIFICATION=
